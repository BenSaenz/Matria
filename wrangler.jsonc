{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matria-site",
  "compatibility_date": "2025-02-04",
  "pages_build_output_dir": ".",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "matria",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ]
}
